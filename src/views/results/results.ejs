<%- include('../partials/head') %>
<%- include('../partials/header') %>

<div class="page-content">
  <div class="page-title-row">
    <h1 class="page-title">Resultados</h1>
    <div class="page-title-actions">
      <button class="btn btn-secondary" id="openFilterBtn">
        <i class="fa-solid fa-filter"></i> Filtros
      </button>
    </div>
  </div>

  <div class="active-filters-bar" id="activeFiltersBar" style="display: none;">
    <span class="active-filters-text">Filtros aplicados</span>
    <button class="btn-clear-filters" id="clearFiltersBtn">
      <i class="fa-solid fa-xmark"></i> Quitar filtros
    </button>
  </div>

  <div class="table-scroll-container" id="tableScrollContainer" style="--table-height: calc(100vh - 190px)">
    <table class="std-table results-table">
      <colgroup>
        <col style="width: 45px">
        <col style="width: 60px">
        <col style="width: 140px">
        <col style="width: 180px">
        <col style="width: 120px">
        <col style="width: 180px">
        <col style="width: 120px">
        <col style="width: 70px">
        <col style="width: 90px">
        <col style="width: 110px">
        <col style="width: 120px">
        <col style="width: 90px">
      </colgroup>
      <thead>
        <tr>
          <th><input type="checkbox" id="selectAllCheckbox" title="Seleccionar todos"></th>
          <th class="th-sortable" data-sort="id">ID <i class="fa-solid fa-arrow-down-short-wide sort-icon"></i></th>
          <th class="th-sortable" data-sort="company">Empresa <i class="fa-solid fa-arrow-down-short-wide sort-icon"></i></th>
          <th class="th-sortable" data-sort="course">Curso <i class="fa-solid fa-arrow-down-short-wide sort-icon"></i></th>
          <th>Evento</th>
          <th class="th-sortable" data-sort="student_name">Apellido y Nombre <i class="fa-solid fa-arrow-down-short-wide sort-icon"></i></th>
          <th class="th-sortable" data-sort="status">Estado <i class="fa-solid fa-arrow-down-short-wide sort-icon"></i></th>
          <th>Nota</th>
          <th>Validez</th>
          <th class="th-sortable" data-sort="updated_at">Fecha <i class="fa-solid fa-arrow-down-short-wide sort-icon"></i></th>
          <th>Expiración</th>
          <th>Acciones</th>
        </tr>
      </thead>
      <tbody id="resultsTableBody">
        <!-- rows loaded via JS -->
      </tbody>
    </table>
  </div>
</div>

<!-- Filter Side Panel -->
<div class="filter-panel" id="filterPanel">
  <div class="filter-panel-header">
    <h3 class="filter-panel-title">Filtros</h3>
    <i class="fa-solid fa-xmark filter-panel-close" id="filterPanelClose"></i>
  </div>
  <div class="filter-panel-body">
    <div class="input-group">
      <label class="input-label">Nombre / Apellido</label>
      <input type="text" class="input-field" id="filterName" autocomplete="off" placeholder="Buscar por nombre...">
    </div>
    <div class="input-group">
      <label class="input-label">Curso</label>
      <select class="input-field" id="filterCourse">
        <option value="">Todos</option>
      </select>
    </div>
    <% if ([1, 2, 4].includes(userLogged.id_users_categories)) { %>
    <div class="input-group" id="filterCompanyGroup">
      <label class="input-label">Empresa</label>
      <input type="text" class="input-field" id="filterCompany" autocomplete="off" placeholder="Buscar por empresa...">
    </div>
    <% } %>
    <div class="input-group">
      <label class="input-label">DNI</label>
      <input type="text" class="input-field" id="filterDni" autocomplete="off" placeholder="Buscar por DNI...">
    </div>
    <div class="input-group">
      <label class="input-label">Email</label>
      <input type="text" class="input-field" id="filterEmail" autocomplete="off" placeholder="Buscar por email...">
    </div>
    <div class="input-group">
      <label class="input-label">Estado</label>
      <select class="input-field" id="filterStatus">
        <option value="">Todos</option>
        <option value="pending">Pendiente</option>
        <option value="in-progress">En proceso</option>
        <option value="passed">Aprobado</option>
        <option value="not-passed">Desaprobado</option>
      </select>
    </div>
  </div>
  <div class="filter-panel-footer">
    <button class="btn btn-secondary" id="filterClearBtn">Limpiar</button>
    <button class="btn btn-primary" id="filterApplyBtn">Aplicar</button>
  </div>
</div>
<div class="filter-panel-overlay" id="filterPanelOverlay"></div>

<!-- Result Popup -->
<div class="result-popup" id="resultPopup">
  <i class="fa-solid fa-check result-popup-icon"></i>
  <span class="result-popup-text" id="resultPopupText">Operación exitosa</span>
</div>

<!----------SCRIPTS---------->
<script>
  window.userLogged = { id_users_categories: <%= userLogged.id_users_categories %>, id_companies: <%= userLogged.id_companies || 'null' %> }
</script>
<script type="module" src="/js/results/results.js"></script>
